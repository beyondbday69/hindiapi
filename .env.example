# Tatakai API Environment Variables

# Server Configuration
PORT=4000
NODE_ENV=development

# Redis Configuration (optional - will use in-memory cache if not set)
REDIS_URL=

# CORS Configuration (comma-separated origins, or * for all)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000,*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Cache Configuration
CACHE_TTL_SECONDS=300

# API Hostname (optional - enables health check and rate limiting)
API_HOSTNAME=

# Deployment Environment (nodejs, vercel, cloudflare-workers, render)
DEPLOYMENT_ENV=nodejs

# API Base URL
BASE_URL=http://localhost:4000/api/v1

# TMDB API Key (optional - for movie metadata)
TMDB_KEY=

# API Encryption Secret (must match frontend's VITE_API_SECRET)
# Leave empty to disable request signing
API_SECRET=

# Discord Webhooks (keep these secret — never expose to frontend)
DISCORD_WEBHOOK_USER_CREATED=
DISCORD_WEBHOOK_ERROR_LOGS=
DISCORD_WEBHOOK_COMMENT=
DISCORD_WEBHOOK_REVIEW_POPUP=

# Supabase Configuration (for WatchAnimeWorld scraper)
SUPABASE_URL=
SUPABASE_AUTH_KEY=
